{
  "$schema": "./skills.schema.json",
  "source": {
    "repo": "https://github.com/addyosmani/agent-skills.git",
    "ref": "main"
  },
  "alwaysOn": [
    {
      "name": "incremental-implementation",
      "applyTo": "**",
      "note": "Thin vertical slices for any multi-file change."
    },
    {
      "name": "git-workflow-and-versioning",
      "applyTo": "**",
      "note": "Atomic commits, ~100-line change sizing."
    },
    {
      "name": "code-review-and-quality",
      "applyTo": "**",
      "note": "Five-axis review applied to every diff."
    },
    {
      "name": "debugging-and-error-recovery",
      "applyTo": "**",
      "note": "Five-step triage when things break."
    },
    {
      "name": "test-driven-development",
      "applyTo": "**/*.{ts,tsx,js,jsx,mjs,cjs}",
      "note": "Red-Green-Refactor for code files only."
    },
    {
      "name": "frontend-ui-engineering",
      "applyTo": "**/*.{tsx,jsx,css,scss,less}",
      "note": "Component architecture + a11y for UI files."
    },
    {
      "name": "security-and-hardening",
      "applyTo": "{**/api/**,**/auth/**,middleware*.ts,middleware*.js,**/*.security.ts}",
      "note": "OWASP coverage for boundary code."
    },
    {
      "name": "spec-driven-development",
      "applyTo": "**/*.md",
      "note": "PRD discipline when editing specs/docs."
    },
    {
      "name": "planning-and-task-breakdown",
      "applyTo": "**/*.md",
      "note": "Decompose specs into atomic tasks."
    },
    {
      "name": "documentation-and-adrs",
      "applyTo": "**/*.md",
      "note": "Document the why, not just the what."
    }
  ],
  "onDemand": [
    "idea-refine",
    "context-engineering",
    "source-driven-development",
    "api-and-interface-design",
    "browser-testing-with-devtools",
    "code-simplification",
    "performance-optimization",
    "ci-cd-and-automation",
    "deprecation-and-migration",
    "shipping-and-launch"
  ],
  "slashCommands": [
    "spec",
    "plan",
    "build",
    "test",
    "review",
    "code-simplify",
    "ship"
  ],
  "personas": [
    "code-reviewer",
    "test-engineer",
    "security-auditor"
  ]
}
